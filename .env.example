# API Key cho Gemini (Google Generative AI) - BẮT BUỘC
GEMINI_API_KEY=your_gemini_api_key_here

# API Key cho Groq - Tùy chọn (Nếu muốn dùng Groq OCR)
GROQ_API_KEY=your_groq_api_key_here

# Cấu hình Model cho Gemini (Mặc định: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Cấu hình Model cho Groq (Mặc định: qwen/qwen3-32b)
# GROQ_MODEL=qwen/qwen3-32b

# Link model free tier Groq: https://console.groq.com/docs/rate-limits


# Cổng mạng để chạy ứng dụng Node.js (Mặc định: 4173)
PORT=4173

# Đường dẫn Python nếu cần cấu hình thủ công (Tùy chọn)
# CONTRACTGUARD_PYTHON=python3

# Đường dẫn Tesseract OCR nếu cần cấu hình thủ công (Tùy chọn)
# CONTRACTGUARD_TESSERACT=/opt/homebrew/bin/tesseract
